{
 "$schema": "https://biomejs.dev/schemas/1.7.3/schema.json",
 "linter": {
  "enabled": true,
  "rules": {
   "recommended": true,
    "biome.semicolons": "asNeeded",
    "biome.trailingCommas": "all"
  }
 },
 "formatter": {
  "enabled": true,
  "indentWidth": 2,
  "indentStyle": "space",
  "formatWithErrors": true,
  "lineWidth": 120
 }
}
