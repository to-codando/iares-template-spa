{
  "compilerOptions": {
    "rootDir": "..",
    "baseUrl": "../src",
    "outDir": "../dist",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "paths": {
      "@/store": [
        "store/index.ts"
      ],
      "@/components/*": [
        "components/*"
      ],
      "@/utils/*": [
        "utils/*"
      ],
      "@/services/*": [
        "services/*"
      ],
      "@/assets/*": [
        "public/assets/*"
      ],
      "@/tests/*": [
        "tests/*"
      ],
      "@/mock/*": [
        "mock/*"
      ]
    },
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "target": "es2018",
    "module": "esnext",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSourceMap": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "config",
    "public",
    "api",
    ".vscode"
  ],
  "include": [
    "src/**/*",
    "./config/declarations.d.ts"
  ]
}
