{
  "compilerOptions": {
    "baseUrl": "./",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "paths": {
      "@/store": [
        "src/store/index.ts"
      ],
      "@/components/*": [
        "src/components/*"
      ],
      "@/utils/*": [
        "src/utils/*"
      ],
      "@/services/*": [
        "src/services/*"
      ],
      "@/assets/*": [
        "public/assets/*"
      ],
      "@/tests/*": [
        "src/tests/*"
      ],
      "@/mock/*": [
        "src/mock/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "node",
      "mocha",
      "chai"
    ],
    "strict": true,
    "noEmitOnError": true,
    "esModuleInterop": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "target": "es2018",
    "module": "esnext",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "outDir": "./dist",
    "sourceMap": true,
    "inlineSources": true
  }
}
